# === Shamir Secret Sharing над GF(256) ===
# Поле GF(2^8), редуцирующий многочлен 0x11b (как в AES). Сложение = XOR.
# Умножение — через таблицы log/antilog от генератора 0x03 (примитивный элемент поля).
# Деление/инверсия — через те же таблицы. Все операции — над байтами секрета.
# ПРЕДЕЛ (честно, см. README «Scope & limitations»): умножение через log/antilog-таблицы
# НЕ constant-time — есть тайминговый side-channel. Вне модели угроз локального CLI
# (нет удалённого/онлайн-оракула на split/combine), но мы его не скрываем.

# sha256 → hex (портативно: macOS shasum / Linux sha256sum). Для контрольных сумм.
_sha256_hex() {
  if command -v shasum >/dev/null 2>&1; then shasum -a 256 | cut -d' ' -f1
  else sha256sum | cut -d' ' -f1; fi
}
# bytes(stdin) → hex без пробелов; hex(arg) → raw bytes(stdout). Без xxd (нет на части систем).
_to_hex() { od -An -v -tx1 | tr -d ' \n'; }
_from_hex() { local h="$1" i; for ((i=0; i<${#h}; i+=2)); do printf '%b' "\\x${h:i:2}"; done; }

# Таблицы GF(256): GF_EXP[i]=g^i (g=3), GF_LOG[v]=i. Генерируются один раз.
_gf_init() {
  local x=1 i tt
  GF_EXP=(); GF_LOG=()
  for ((i=0; i<255; i++)); do
    GF_EXP[i]=$x
    GF_LOG[x]=$i
    tt=$(( (x<<1) & 0xff ))                 # xtime(x) = x*2 в GF
    if (( x & 0x80 )); then tt=$(( tt ^ 0x1b )); fi
    x=$(( tt ^ x ))                          # x*3 = xtime(x) XOR x
  done
}

cmd_split() {
  require_macos
  local n=3 t=2 file=""
  while (( $# )); do
    case "$1" in
      -n|--shares)    n="${2:?}"; shift 2 ;;
      -t|--threshold) t="${2:?}"; shift 2 ;;
      --file)         file="${2:?}"; shift 2 ;;
      *) err "$(t split_bad_arg "$1")"; exit 1 ;;
    esac
  done

  # Секрет — из stdin или --file, в hex. Никогда из argv (виден в `ps`).
  local secret_hex
  if [[ -n "$file" ]]; then
    [[ -r "$file" ]] || { err "$(t split_file_unreadable "$file")"; exit 1; }
    secret_hex="$(_to_hex < "$file")"
  else
    secret_hex="$(_to_hex)"
  fi
  [[ -n "$secret_hex" ]] || { err "$(t split_empty_secret)"; exit 1; }

  [[ "$n" =~ ^[0-9]+$ && "$t" =~ ^[0-9]+$ ]] || { err "$(t split_nt_not_num)"; exit 1; }
  (( t >= 2 )) || { err "$(t split_t_min)"; exit 1; }
  (( n >= t )) || { err "$(t split_n_lt_t "$n" "$t")"; exit 1; }
  (( n <= 255 )) || { err "$(t split_n_max)"; exit 1; }

  local L=$(( ${#secret_hex} / 2 ))
  (( L <= 65535 )) || { err "$(t split_secret_big)"; exit 1; }

  # Случайный set-id (4-байтный nonce) — НЕ производный от секрета (иначе confirmation-оракул:
  # имея одну долю + кандидат-секрет, можно было бы проверить догадку, не собирая порог).
  # Одинаков во всех долях набора → combine ДЕТЕРМИНИРОВАННО отвергает смешивание долей
  # из разных сплитов (а не вероятностно).
  local setid_hex
  setid_hex="$(head -c 4 /dev/urandom | _to_hex)"
  [[ ${#setid_hex} -eq 8 ]] || { err "$(t split_low_entropy)"; exit 1; }

  # Обёртка целостности: 0x55 | len(2B BE) | secret | tag(16B = первые 16 байт sha256 предыдущего).
  # 128-битный tag: combine вернёт ЛИБО точный секрет, ЛИБО честный отказ; шанс молча отдать
  # НЕ тот секрет ≈ 2^-128 (против 2^-16 у старого 2-байтного CRC).
  local hi=$(( L >> 8 )) lo=$(( L & 0xff )) core_hex tag_hex
  printf -v core_hex '55%02x%02x%s' "$hi" "$lo" "$secret_hex"
  tag_hex="$(_from_hex "$core_hex" | _sha256_hex)"; tag_hex="${tag_hex:0:32}"
  local payload_hex="${core_hex}${tag_hex}" PL
  PL=$(( ${#payload_hex} / 2 ))

  local -a P=(); local k
  for ((k=0; k<PL; k++)); do P[k]=$(( 16#${payload_hex:k*2:2} )); done

  _gf_init

  # (t-1) случайных байт на каждый байт payload — старшие коэффициенты многочленов.
  local need=$(( (t-1) * PL )) rand_hex
  rand_hex="$(head -c "$need" /dev/urandom | _to_hex)"
  [[ ${#rand_hex} -eq $((need*2)) ]] || { err "$(t split_low_entropy)"; exit 1; }

  local -a Y=(); local x j ri=0 y hb
  for ((x=1; x<=n; x++)); do Y[x]=""; done
  for ((k=0; k<PL; k++)); do
    # Многочлен байта k: c0=P[k] (секрет), c1..c_{t-1} = случайные. Оцениваем в x=1..n (Горнер).
    local -a C=(); C[0]=${P[k]}
    for ((j=1; j<t; j++)); do C[j]=$(( 16#${rand_hex:ri*2:2} )); ri=$((ri+1)); done
    for ((x=1; x<=n; x++)); do
      y=${C[t-1]}
      for ((j=t-2; j>=0; j--)); do
        if (( y != 0 )); then y=${GF_EXP[$(( (GF_LOG[y]+GF_LOG[x]) % 255 ))]}; fi
        y=$(( y ^ C[j] ))
      done
      printf -v hb '%02x' "$y"; Y[x]+="$hb"
    done
  done

  # Доля: SSS2-<setid>-<T>-<x>-<hexY>-<chk4>. chk ловит опечатку в конкретной доле;
  # setid — смешивание долей из разных сплитов. Формат SSS2 НЕсовместим со старым SSS1.
  for ((x=1; x<=n; x++)); do
    local body="SSS2-${setid_hex}-${t}-${x}-${Y[x]}" chk
    chk="$(printf '%s' "$body" | _sha256_hex)"; chk="${chk:0:4}"
    printf '%s-%s\n' "$body" "$chk"
  done
}

# Восстановление секрета из долей: парсинг + ВСЕ проверки + интерполяция Лагранжа в нуле.
# Печатает secret_hex в stdout при успехе; при ЛЮБОЙ ошибке — сообщение в stderr и `return !=0`
# (НЕ exit: функция зовётся в $(...), exit убил бы только subshell и оставил вызывающего без
# проверки статуса). Таксономия ошибок различает: не-SSS2 / порча доли (CRC) / разные сплиты
# (set-id) / расходящийся порог T / ниже порога / провал целостности payload.
_recover_secret_hex() {
  local raw="$1"
  _gf_init
  local -a XS=() YS=()
  local line ylen="" t_decl="" setid_seen="" cnt=0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    if [[ ! "$line" =~ ^SSS2-([0-9a-f]{8})-([0-9]+)-([0-9]+)-([0-9a-f]+)-([0-9a-f]{4})$ ]]; then
      err "$(t combine_not_sss2 "$line")"; return 1
    fi
    local sid="${BASH_REMATCH[1]}" T="${BASH_REMATCH[2]}" x="${BASH_REMATCH[3]}" yh="${BASH_REMATCH[4]}" chk="${BASH_REMATCH[5]}"
    local body="SSS2-${sid}-${T}-${x}-${yh}" want
    want="$(printf '%s' "$body" | _sha256_hex)"; want="${want:0:4}"
    [[ "$chk" == "$want" ]] || { err "$(t combine_corrupt "$x")"; return 1; }
    (( x >= 1 && x <= 255 )) || { err "$(t combine_bad_x "$x")"; return 1; }
    # set-id: все доли набора обязаны совпадать (детерминированный отказ при смешивании сплитов).
    if [[ -z "$setid_seen" ]]; then setid_seen="$sid"
    elif [[ "$sid" != "$setid_seen" ]]; then
      err "$(t combine_diff_splits "$sid" "$setid_seen")"; return 1
    fi
    # declared-T: все доли обязаны заявлять одинаковый порог.
    if [[ -z "$t_decl" ]]; then t_decl="$T"
    elif [[ "$T" != "$t_decl" ]]; then
      err "$(t combine_diff_t "$T" "$t_decl")"; return 1
    fi
    local d; for d in "${XS[@]:-}"; do [[ "$d" == "$x" ]] && { err "$(t combine_dup "$x")"; return 1; }; done
    [[ -z "$ylen" ]] && ylen="${#yh}"
    [[ "${#yh}" -eq "$ylen" ]] || { err "$(t combine_diff_len)"; return 1; }
    XS+=("$x"); YS+=("$yh"); cnt=$((cnt+1))
  done <<< "$raw"

  (( cnt >= 1 )) || { err "$(t combine_no_shares)"; return 1; }
  if [[ -n "$t_decl" ]] && (( cnt < t_decl )); then
    err "$(t combine_below "$t_decl" "$cnt")"; return 1
  fi

  # Веса Лагранжа в нуле (одинаковы для всех байтов): w_i = prod_{j!=i} x_j * inv(x_i XOR x_j).
  local m=$cnt i j
  local -a W=()
  for ((i=0; i<m; i++)); do
    local num=1 xi="${XS[i]}"
    for ((j=0; j<m; j++)); do
      (( j == i )) && continue
      local xj="${XS[j]}"; local den=$(( xi ^ xj ))
      (( den != 0 )) || { err "$(t combine_coincident)"; return 1; }
      num=${GF_EXP[$(( (GF_LOG[num]+GF_LOG[xj]) % 255 ))]}                 # num *= x_j
      num=${GF_EXP[$(( (GF_LOG[num]+(255-GF_LOG[den])%255) % 255 ))]}      # num *= inv(den)
    done
    W[i]=$num
  done

  # Восстановление каждого байта payload: acc = XOR_i ( y_i[p] * w_i ).
  local PL=$(( ylen / 2 )) p payload_hex="" acc yb term hb
  for ((p=0; p<PL; p++)); do
    acc=0
    for ((i=0; i<m; i++)); do
      yb=$(( 16#${YS[i]:p*2:2} ))
      if (( yb != 0 )); then
        term=${GF_EXP[$(( (GF_LOG[yb]+GF_LOG[W[i]]) % 255 ))]}
        acc=$(( acc ^ term ))
      fi
    done
    printf -v hb '%02x' "$acc"; payload_hex+="$hb"
  done

  # Проверка обёртки (16-байтный tag): magic(0x55) | len(2) | secret | tag(16).
  local fail; fail="$(t combine_integrity)"
  (( PL >= 20 )) || { err "$fail"; return 1; }          # 1 magic + 2 len + >=1 secret + 16 tag
  (( 16#${payload_hex:0:2} == 0x55 )) || { err "$fail"; return 1; }
  local len=$(( 16#${payload_hex:2:4} ))
  (( PL == len + 19 )) || { err "$fail"; return 1; }     # 1 + 2 + len + 16
  local core_hex="${payload_hex:0:$(( (len+3)*2 ))}" tag_have="${payload_hex: -32}" tag_want
  tag_want="$(_from_hex "$core_hex" | _sha256_hex)"; tag_want="${tag_want:0:32}"
  [[ "$tag_have" == "$tag_want" ]] || { err "$fail"; return 1; }

  printf '%s' "${payload_hex:6:$(( len*2 ))}"
}

cmd_combine() {
  require_macos
  local raw; if (( $# )); then raw="$(cat "$@")"; else raw="$(cat)"; fi
  local sh; sh="$(_recover_secret_hex "$raw")" || exit 1
  _from_hex "$sh"
}

# verify: проверить, что доли образуют валидный набор и секрет восстановим — БЕЗ его печати
# (полезно при раскладке долей по носителям: подтвердить корректность, не раскрывая секрет).
cmd_verify() {
  require_macos
  local raw; if (( $# )); then raw="$(cat "$@")"; else raw="$(cat)"; fi
  local sh; sh="$(_recover_secret_hex "$raw")" || exit 1
  local n=$(( ${#sh} / 2 ))
  info "$(t verify_ok "$n")"
}

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then usage; exit 1; fi
  shift || true
  case "$cmd" in
    version|-v|--version) cmd_version "$@" ;;
    help|--help|-h) usage ;;
    split)          cmd_split "$@" ;;
    combine)        cmd_combine "$@" ;;
    verify)         cmd_verify "$@" ;;
    *) t unknown_cmd "$cmd" >&2; echo >&2; usage >&2; exit 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
